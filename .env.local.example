# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Protect /admin (recommended for any shared or production deploy)
ADMIN_SECRET=change-me

# Signs game session state on the server (falls back to ADMIN_SECRET in dev)
# GAME_STATE_SECRET=change-me-too
